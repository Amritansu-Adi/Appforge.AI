# =============================================================
# AppForge AI Service — Python Environment Variables
# Copy to ai-service/.env and fill in values.
# NEVER commit .env to git.
# =============================================================

# --- LLM API Keys (Required) ---
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Internal Service Auth (Required — must match root .env AI_SERVICE_SECRET) ---
AI_SERVICE_SECRET=your_internal_shared_secret_here

# --- LangSmith Tracing (Optional — dev only) ---
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=appforge-dev

# --- Port Config ---
AI_PORT=8000

# --- v4.0: Python owns its own separate DB file (NOT the same as Node.js appforge.db) ---
LG_DB_PATH=./data/langgraph.db
