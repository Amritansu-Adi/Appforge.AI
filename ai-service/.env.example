# =============================================================
# AppForge AI Service (Python) — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================

# --- LLM API Keys (Required) ---
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Internal Auth (Required — must match Node.js AI_SERVICE_SECRET) ---
# Generate with: openssl rand -base64 32
AI_SERVICE_SECRET=your_internal_shared_secret_here

# --- Database (must point to same file as Node.js DB_PATH) ---
DB_PATH=../data/appforge.db

# --- LangSmith Tracing (Optional — dev only) ---
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=appforge-dev

# --- Service Config ---
AI_PORT=8000
