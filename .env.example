# =============================================================
# AppForge AI — Root Environment Variables
# Copy this file to .env and fill in your values.
# The Python AI service has its own ai-service/.env.example
# NEVER commit .env to git.
# =============================================================

# --- LLM API Keys (Required — Python AI service) ---
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Auth (Required — Node.js only) ---
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# --- Internal Service Auth (Required — must match ai-service/.env AI_SERVICE_SECRET) ---
# Generate with: openssl rand -base64 32
AI_SERVICE_SECRET=your_internal_shared_secret_here

# --- Service URLs ---
AI_SERVICE_URL=http://localhost:8000

# --- LangSmith Tracing (Optional — dev only) ---
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=appforge-dev

# --- Server Config ---
NODE_ENV=development
PORT=3001

# --- Database Paths (v4.0: TWO SEPARATE DB FILES) ---
# Node.js exclusively owns appforge.db
DB_PATH=./data/appforge.db
# Python AI service exclusively owns langgraph.db (SqliteSaver checkpoints)
LG_DB_PATH=./data/langgraph.db

# --- Port Config ---
AI_PORT=8000
